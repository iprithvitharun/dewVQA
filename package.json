{
  "name": "dew-vqa-extension",
  "version": "0.1.0",
  "description": "Chrome extension for automated Visual QA testing against Dew Design System tokens and Figma frames.",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build:tokens": "tsx scripts/build-tokens.ts && tsx scripts/build-component-specs.ts",
    "build:ext": "node esbuild.config.mjs",
    "build": "npm run clean && npm run build:tokens && npm run build:ext",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
